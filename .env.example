# Секретный ключ приложения (обязательно, без него приложение не запустится)
# Используется для шифрования всех токенов в БД (Fernet) и подписи сессионных кук.
# ВНИМАНИЕ: смена ключа в продакшене делает все зашифрованные значения в БД нечитаемыми.
# Сгенерировать новый ключ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<замените на случайный hex-32>

# База данных
# SQLite (по умолчанию, файл создаётся автоматически):
# DATABASE_URL=sqlite:///data/admin.db
#
# PostgreSQL (облачная БД):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///data/admin.db

# ── Docker / self-host ───────────────────────────────────────────────────────

# Часовой пояс контейнера. Влияет на системное время внутри контейнера,
# но не на хранение дат: scheduled_at хранится в UTC (см. rules/database/schema.md).
TZ=Europe/Moscow

# Уровень логирования приложения. Допустимые значения: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Порт, на котором Uvicorn принимает соединения внутри контейнера.
# Изменяйте здесь и в docker-compose.yml одновременно.
PORT=8000

# Учётные данные первого суперадмина, создаваемого при пустой БД.
# Если переменные не заданы — создаётся admin/admin (небезопасно!).
# Задайте перед первым запуском и храните в тайне.
# После первого запуска изменить пароль можно через /admin или create_superadmin.py.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Публичный базовый URL приложения (без слэша на конце).
# Используется webhook-publisher'ом для построения АБСОЛЮТНЫХ image_urls
# в payload — иначе получатель вебхука получит "/data/uploads/..."
# и не сможет скачать изображение.
# Если переменная не задана — image_urls остаются относительными
# (обратная совместимость со старыми получателями).
# Пример: PUBLIC_BASE_URL=https://postery.example.com
PUBLIC_BASE_URL=
